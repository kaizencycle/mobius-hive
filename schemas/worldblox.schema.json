{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "type", "zone", "state"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "zone": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "state": {
      "type": "string",
      "enum": ["draft", "simulated", "attested", "sealed", "quarantined", "timed_out", "legacy"]
    },
    "cycle": { "type": "string" },
    "day": { "type": "integer", "minimum": 1 },
    "source_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "gi": { "type": "number" },
        "mii": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "support": {
      "type": "object",
      "properties": {
        "agents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "decay": {
      "type": "object",
      "properties": {
        "born_day": { "type": "integer", "minimum": 1 },
        "ttl_days": { "type": "integer", "minimum": 1 },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
